[Unit]
Description=uStreamer camera service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=vitor
ExecStart=homevitorustreamerustreamer --device=devvideo0 --host=0.0.0.0 --port=8080 --resolution=640x480 --desired-fps=30 --format=MJPEG
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target